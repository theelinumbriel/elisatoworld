---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
  description?: string;
  /** home hides the top bar and lets the page own the full viewport */
  home?: boolean;
}

const {
  title = 'elisa marie diop-weyer',
  description = 'elisa marie diop-weyer — portfolio',
  home = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    {
      !home && (
        <header class="topbar">
          <a class="brand" href="/">elisa marie diop-weyer</a>
          <Nav />
        </header>
      )
    }
    <main>
      <slot />
    </main>
  </body>
</html>
