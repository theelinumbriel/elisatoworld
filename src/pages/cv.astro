---
import Base from '../layouts/Base.astro';

const cvPath = '/cv/elisa-marie-diop-weyer-cv.pdf';
---

<Base title="cv — elisa marie diop-weyer">
  <section class="cv">
    <div class="head">
      <h1 class="title" style="view-transition-name: nav-cv">cv</h1>
      <a href={cvPath} target="_blank" rel="noopener">download (pdf)</a>
    </div>
    <object class="viewer" data={cvPath} type="application/pdf">
      <p>
        your browser can't display the pdf inline —
        <a href={cvPath} target="_blank" rel="noopener">download it here</a>.
      </p>
    </object>
  </section>
</Base>

<style>
  .cv {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .head {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
  }

  .viewer {
    width: 100%;
    height: calc(100vh - 12rem);
    min-height: 28rem;
    border: 1px solid #000;
  }
</style>
